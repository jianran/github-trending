# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_SUMMARY_CHANNEL_ID=123456789012345678
DISCORD_DM_USER_IDS=123456789012345678,987654321098765432

# llamacpp Server Configuration
LLAMACPP_SERVER_URL=http://localhost:8080
LLAMACPP_MODEL=llama2

# GitHub Trending Configuration
GITHUB_TRENDING_PERIOD=daily
GITHUB_TRENDING_TOP=10

# Summary Schedule (Cron expression)
# Default: Every day at 9:00 AM
SUMMARY_SCHEDULE_CRON=0 0 9 * * *

# Custom Summary Prompt (optional)
# SUMMARY_PROMPT_TEMPLATE=
